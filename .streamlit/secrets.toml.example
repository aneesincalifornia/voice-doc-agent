# Copy this file to .streamlit/secrets.toml for local development.
# NEVER commit the real secrets.toml — it's gitignored.
#
# When deployed on Streamlit Community Cloud, set these same keys under
# your app's Settings → Secrets in the web UI instead of this file.

OPENAI_API_KEY = "sk-your-key-here"

# The password visitors must enter before using the app.
# Leave blank/remove this line to disable the password gate (not recommended
# for a publicly shared link, since it runs on your API key).
APP_PASSWORD = "choose-a-password"

# Optional overrides (same as .env for the CLI version)
CHAT_MODEL = "gpt-4o-mini"
TTS_VOICE = "alloy"
RELEVANCE_THRESHOLD = "0.5"
